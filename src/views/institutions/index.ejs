<%- include('../partials/layoutStart', { title, bodyClass: 'app-page', pageHeading, pageDescription, currentPath, currentUser, success, error }) %>

<section class="panel-card">
  <div class="panel-heading panel-heading-inline">
    <h2>Institution Register</h2>
    <a class="btn btn-primary" href="/institutions/new">Register New Institution</a>
  </div>

  <% if (!institutions.length) { %>
    <div class="empty-box">
      <p class="empty-state">No institutions registered yet.</p>
    </div>
  <% } else { %>
    <div class="toolbar">
      <input type="search" class="form-input" placeholder="Search institutions" data-table-filter="#institutions-table">
    </div>
    <div class="table-wrap">
      <table class="data-table" id="institutions-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Town</th>
            <th>County</th>
            <th>Contact</th>
            <th>Phone</th>
            <th>Bandwidth</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% institutions.forEach((institution) => { %>
            <tr>
              <td data-label="Name"><%= institution.name %></td>
              <td data-label="Type"><%= institution.institution_type %></td>
              <td data-label="Town"><%= institution.town %></td>
              <td data-label="County"><%= institution.county %></td>
              <td data-label="Contact"><%= institution.contact_name || '-' %></td>
              <td data-label="Phone"><%= institution.contact_phone || '-' %></td>
              <td data-label="Bandwidth"><%= institution.speed_label %></td>
              <td data-label="Status"><span class="status-pill"><%= institution.status %></span></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('../partials/layoutEnd') %>
