{
  "name": "azani-isp-system",
  "version": "1.0.0",
  "description": "Azani Internet Service Provider Information System - Database Management System for managing institution registration, payments, infrastructure, upgrades, and reporting.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "node src/database/scripts/migrate.js",
    "db:seed": "node src/database/scripts/seed.js",
    "test": "jest --runInBand --verbose",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "convert-docs": "python convert_docs.py"
  },
  "keywords": [
    "isp",
    "database",
    "management",
    "azani",
    "kcse"
  ],
  "author": "Derrick",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-flash": "^0.0.2",
    "express-session": "^1.18.1",
    "method-override": "^3.0.0",
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jest": "^30.3.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
  }
}
