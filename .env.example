# -------------------------------------------------------
# LOCAL DEVELOPMENT — use individual DB vars
# -------------------------------------------------------
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=azani_isp
DB_PORT=3306

# -------------------------------------------------------
# RAILWAY DEPLOYMENT — Railway sets MYSQL_URL automatically
# when you add a MySQL plugin. You only need to set these:
# -------------------------------------------------------
# MYSQL_URL=mysql://user:password@host:port/database  (set by Railway)
# SESSION_SECRET=<generate a long random string>
# NODE_ENV=production

# Application
PORT=3000
SESSION_SECRET=azani-isp-secret-key-change-in-production
NODE_ENV=development
